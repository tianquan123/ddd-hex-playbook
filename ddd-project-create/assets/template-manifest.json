{
  "template_version": "2.0.0",
  "placeholders": [
    "__DDD_PROJECT_NAME__",
    "__DDD_GROUP_ID__",
    "__DDD_BASE_PACKAGE__",
    "__DDD_BASE_PACKAGE_PATH__",
    "__DDD_PROJECT_CLASS__"
  ],
  "text_extensions": [
    ".cmd",
    ".java",
    ".md",
    ".properties",
    ".xml",
    ".yaml",
    ".yml"
  ],
  "text_filenames": [
    ".gitignore",
    "mvnw"
  ],
  "required_paths": [
    "pom.xml",
    "mvnw",
    "mvnw.cmd",
    ".mvn/wrapper/maven-wrapper.properties",
    "__DDD_PROJECT_NAME__-api/pom.xml",
    "__DDD_PROJECT_NAME__-domain/pom.xml",
    "__DDD_PROJECT_NAME__-application/pom.xml",
    "__DDD_PROJECT_NAME__-infra/pom.xml",
    "__DDD_PROJECT_NAME__-trigger/pom.xml",
    "__DDD_PROJECT_NAME__-starter/pom.xml",
    "__DDD_PROJECT_NAME__-api/src/main/java/__DDD_BASE_PACKAGE_PATH__/api/SampleOrderApi.java",
    "__DDD_PROJECT_NAME__-api/src/main/java/__DDD_BASE_PACKAGE_PATH__/facade/SampleOrderFacade.java",
    "__DDD_PROJECT_NAME__-domain/src/main/java/__DDD_BASE_PACKAGE_PATH__/domain/sampleorder/model/SampleOrder.java",
    "__DDD_PROJECT_NAME__-domain/src/main/java/__DDD_BASE_PACKAGE_PATH__/domain/sampleorder/repository/SampleOrderRepository.java",
    "__DDD_PROJECT_NAME__-application/src/main/java/__DDD_BASE_PACKAGE_PATH__/application/sampleorder/service/SampleOrderAppService.java",
    "__DDD_PROJECT_NAME__-application/src/main/java/__DDD_BASE_PACKAGE_PATH__/application/sampleorder/service/impl/SampleOrderAppServiceImpl.java",
    "__DDD_PROJECT_NAME__-infra/src/main/java/__DDD_BASE_PACKAGE_PATH__/infra/sampleorder/adapter/SampleOrderPersistenceAdapter.java",
    "__DDD_PROJECT_NAME__-infra/src/main/java/__DDD_BASE_PACKAGE_PATH__/infra/sampleorder/persistence/entity/SampleOrderDO.java",
    "__DDD_PROJECT_NAME__-infra/src/main/java/__DDD_BASE_PACKAGE_PATH__/infra/sampleorder/persistence/mapper/SampleOrderMapper.java",
    "__DDD_PROJECT_NAME__-infra/src/main/resources/mapper/sampleorder/SampleOrderMapper.xml",
    "__DDD_PROJECT_NAME__-trigger/src/main/java/__DDD_BASE_PACKAGE_PATH__/trigger/http/sampleorder/SampleOrderController.java",
    "__DDD_PROJECT_NAME__-trigger/src/main/java/__DDD_BASE_PACKAGE_PATH__/trigger/http/sampleorder/SampleOrderHttpConverter.java",
    "__DDD_PROJECT_NAME__-trigger/src/main/java/__DDD_BASE_PACKAGE_PATH__/trigger/rpc/sampleorder/SampleOrderProvider.java",
    "__DDD_PROJECT_NAME__-starter/src/main/java/__DDD_BASE_PACKAGE_PATH__/bean/SampleOrderBeanConfiguration.java",
    "__DDD_PROJECT_NAME__-starter/src/main/resources/application.yml",
    "__DDD_PROJECT_NAME__-starter/src/main/resources/schema.sql",
    "__DDD_PROJECT_NAME__-starter/src/main/java/__DDD_BASE_PACKAGE_PATH__/__DDD_PROJECT_CLASS__Application.java"
  ],
  "forbidden_tokens": [
    "__DDD_"
  ],
  "required_content": {
    "pom.xml": [
      "<groupId>__DDD_GROUP_ID__</groupId>",
      "<artifactId>__DDD_PROJECT_NAME__</artifactId>"
    ],
    "__DDD_PROJECT_NAME__-starter/src/main/java/__DDD_BASE_PACKAGE_PATH__/__DDD_PROJECT_CLASS__Application.java": [
      "package __DDD_BASE_PACKAGE__;",
      "public class __DDD_PROJECT_CLASS__Application"
    ],
    "__DDD_PROJECT_NAME__-trigger/src/main/java/__DDD_BASE_PACKAGE_PATH__/trigger/http/sampleorder/SampleOrderHttpConverter.java": [
      "Mappers.getMapper(SampleOrderHttpConverter.class)",
      "unmappedTargetPolicy = ReportingPolicy.ERROR"
    ],
    "__DDD_PROJECT_NAME__-infra/src/main/resources/mapper/sampleorder/SampleOrderMapper.xml": [
      "namespace=\"__DDD_BASE_PACKAGE__.infra.sampleorder.persistence.mapper.SampleOrderMapper\""
    ],
    "__DDD_PROJECT_NAME__-starter/src/main/java/__DDD_BASE_PACKAGE_PATH__/bean/SampleOrderBeanConfiguration.java": [
      "package __DDD_BASE_PACKAGE__.bean;",
      "new SampleOrderAppServiceImpl(repository)",
      "new SampleOrderPersistenceAdapter(mapper)"
    ],
    "__DDD_PROJECT_NAME__-starter/src/main/resources/application.yml": [
      "jdbc:h2:mem:sample-order",
      "DUBBO_REGISTRY_ADDRESS:N/A"
    ]
  },
  "build_commands": {
    "windows": [
      "mvnw.cmd",
      "verify"
    ],
    "posix": [
      "./mvnw",
      "verify"
    ]
  },
  "module_dependencies": {
    "api": [],
    "domain": [],
    "application": ["domain"],
    "infra": ["application", "domain"],
    "trigger": ["api", "application"],
    "starter": ["trigger", "infra", "application", "domain"]
  },
  "java_rules": {
    "forbidden_imports": {
      "domain": ["org.springframework.", "org.apache.dubbo.", "org.mybatis.", ".application.", ".infra.", ".trigger."],
      "application": [".api.", ".facade.", ".infra.", ".trigger."],
      "trigger": [".infra."]
    },
    "suffix_packages": {
      "DO": ".infra.sampleorder.persistence.entity",
      "Controller": ".trigger.http.sampleorder",
      "Provider": ".trigger.rpc.sampleorder",
      "PersistenceAdapter": ".infra.sampleorder.adapter",
      "BeanConfiguration": ".bean"
    },
    "forbid_records": true,
    "mapstruct_required_fragments": [
      "Mappers.getMapper(",
      "unmappedTargetPolicy = ReportingPolicy.ERROR"
    ]
  }
}
